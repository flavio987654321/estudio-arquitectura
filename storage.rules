rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // proyectos/{uid}/{proyectoId}/...
    match /proyectos/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if isOwner(uid)
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
          || (request.resource.contentType == 'application/pdf' && request.resource.size < 10 * 1024 * 1024)
          || (request.resource.contentType.matches('video/.*') && request.resource.size < 200 * 1024 * 1024)
        );
    }

    // site/nosotros/...
    match /site/nosotros/{allPaths=**} {
      allow read: if true;
      allow write: if signedIn()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
